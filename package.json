{
  "name": "ai-agents-team",
  "version": "0.1.15",
  "type": "module",
  "description": "A team of specialized AI agents (coordinator, security, frontend, accessibility, performance, QA) for web development, installable and updatable in any project via CLI.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giuliozulian/ai-agents-team.git"
  },
  "homepage": "https://github.com/giuliozulian/ai-agents-team#readme",
  "bugs": {
    "url": "https://github.com/giuliozulian/ai-agents-team/issues"
  },
  "bin": {
    "ai-agents-team": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsup src/cli.ts --format esm --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "prompts": "^2.4.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
